# Dependencies
node_modules/

# Next.js build output
.next/
out/
tsconfig.tsbuildinfo

# Static-export scratch dir (build-static.mjs parks server-only code here)
.static-export-excluded/

# Environment files hold secrets (Supabase service keys, R2/Stripe creds).
# Only checked-in examples are allowed.
.env
.env.*
!.env.example

# OS / editor noise
.DS_Store
*.log

# Engine build trees and scratch copies (rebuilt by packages/engine/scripts)
packages/engine/build-wasm/
packages/engine/build-wasm-pro/
packages/engine/build-native/
packages/engine/dist.bak/

# Supabase CLI scratch
supabase/.temp/

# The TIC-80 core fork is a nested git checkout (own history, huge vendor
# tree). The web app consumes its prebuilt WASM from apps/web/public/engine,
# so the fork stays local until it gets its own repository.
packages/engine/tic80/

# Doom title: fetched assets and the built payload.
# freedoom1.wad and game.data are ~27MB each and fully reproducible
# (scripts/fetch-freedoom.mjs + scripts/build-doom.mjs), so they are rebuilt
# rather than committed — a blob that size is permanent once it is in history.
games/doom/assets/
apps/web/public/games/doom/

# ScummVM runtime: the built engine (scummvm.js/wasm ~10MB, data/) and the
# fetched Beneath a Steel Sky data (~9MB) are large and fully reproducible
# (scripts/build-scummvm.mjs + scripts/fetch-scummvm-games.mjs), so they are
# rebuilt rather than committed. The small iframe loader is source and stays.
apps/web/public/scummvm/*
!apps/web/public/scummvm/cartbox-boot.html

# SuperTux runtime: the built engine (supertux2.js/wasm ~9MB) and its preloaded
# data package (supertux2.data ~170MB — over GitHub's 100MB file limit) are large
# and fully reproducible (scripts/build-supertux.mjs), so they are rebuilt in the
# deploy rather than committed. The small iframe loader is source and stays.
apps/web/public/supertux/*
!apps/web/public/supertux/cartbox-boot.html

# DOS runtime: the js-dos/DOSBox engine and the C-Dogs game zip are vendored
# under games/cdogs (small, but the engine's upstream URL is a rolling pointer),
# and scripts/fetch-dosbox.mjs assembles them here. The assembled copies are
# regenerated rather than committed; the small iframe loader is source and stays.
apps/web/public/dosbox/*
!apps/web/public/dosbox/cartbox-boot.html
