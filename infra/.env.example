# Copy to .env.local (Next.js) / export in the render worker's environment.
# Values below match the local docker-compose + Supabase CLI defaults.

# --- Supabase (auth + database) ---------------------------------------------
# From `supabase start` output when running the CLI locally.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Public vars for the browser (Next.js). Mirror the two above.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# --- Object storage (R2 in prod; MinIO locally) -----------------------------
R2_ENDPOINT=http://127.0.0.1:9000
R2_ACCESS_KEY_ID=cartbox
R2_SECRET_ACCESS_KEY=cartbox-secret
R2_BUCKET=cartbox-carts
R2_PUBLIC_BASE_URL=http://127.0.0.1:9000/cartbox-carts

# --- Stripe (test mode) ------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_CONNECT_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Engine + render worker --------------------------------------------------
# Browser player loads this; also consumed by the render worker (node build).
NEXT_PUBLIC_ENGINE_URL=/engine/tic80.js
ENGINE_URL=./packages/engine/dist/tic80.js
