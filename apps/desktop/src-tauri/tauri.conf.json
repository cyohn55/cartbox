{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cartbox",
  "version": "0.1.0",
  "identifier": "dev.cartbox.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Cartbox",
        "width": 1120,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; connect-src 'self' https://*.cartbox.dev"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "appimage"],
    "icon": ["icons/icon.png"]
  }
}
