 typedef void(*PixelFunc)(tic_mem* memory, s32 x, s32 y, u8 color);
 
+/*
+ * Cartbox material G-buffer capture (normal + height + specular + roughness +
+ * emissive). When a capture target is installed, every tile pixel a cart blits
+ * (spr/map/textured-triangle) also emits that source texel's authored material
+ * into two planes aligned 1:1 with the visible framebuffer: an RGBA plane
+ * (normal/height/specular/roughness) and a single-byte emissive plane. The host
+ * (packages/player LightingLayer) consumes them to relight the frame with real
+ * per-pixel normals, speculars, and self-illumination instead of a flat matte.
+ *
+ * Material is authored in the cart's high banks (the same convention the editor
+ * uses, MATERIAL_BANK in CartEngine.ts): normal=bank7, height=bank6,
+ * specular=bank5, roughness=bank4, emissive=bank3. A material tilesheet built
+ * over a bank's contiguous tiles+sprites uses the identical index/(x,y) math as
+ * the colour sheet, so a material texel is just the same lookup in a different
+ * bank.
+ *
+ * Targets are raw pointers set from the shim; NULL disables capture so ordinary
+ * (unlit) carts pay nothing. Material persists frame-to-frame like VRAM and is
+ * reset to the flat-matte default per cleared region by tic_api_cls (not wiped
+ * every tick), so carts that draw once without clearing keep their material.
+ * Single-threaded, one console ticks at a time — the same invariant the shim
+ * already relies on for its active-console clock.
+ */
+#define CBX_MAT_CHANNELS 5 /* normal, height, specular, roughness, emissive */
+#define CBX_MAT_LEVELS 16  /* authored ramp steps; mirrors editor MATERIAL_LEVELS */
+
+// Cart bank holding each channel, in CBX_MAT_CHANNELS order.
+static const s32 CbxMatBank[CBX_MAT_CHANNELS] = {
+    TIC_BANKS - 1, TIC_BANKS - 2, TIC_BANKS - 3, TIC_BANKS - 4, TIC_BANKS - 5,
+};
+
+static u8* CbxMatPlane = NULL;  // TIC80_WIDTH*TIC80_HEIGHT*4 (n/h/s/r), NULL = off.
+static u8* CbxEmisPlane = NULL; // TIC80_WIDTH*TIC80_HEIGHT   (emissive), NULL = off.
+
+// The cart bank whose tiles/sprites are currently resident in RAM. Material is
+// authored only for bank 0, so capture is skipped when a foreign bank is synced
+// in (its sprite indices don't line up with the material banks). Defaults to 0,
+// so the common (never-sync) case captures; updated by tic_api_sync.
+static s32 CbxTilesBank = 0;
+
+// Installed by the shim before each tick (see cbx_tick). Public to the module.
+void tic_core_cbx_material_target(void* matPlane, void* emisPlane)
+{
+    CbxMatPlane = (u8*)matPlane;
+    CbxEmisPlane = (u8*)emisPlane;
+}
+
+// Called by tic_api_sync when a bank's tiles/sprites are copied into RAM.
+void tic_core_cbx_tiles_bank(s32 bank)
+{
+    CbxTilesBank = bank;
+}
+
+static inline u8 cbxClampLevel(u8 value)
+{
+    return value > CBX_MAT_LEVELS - 1 ? CBX_MAT_LEVELS - 1 : value;
+}
+
+// True + fills `out` with the material tilesheets mirroring the colour sheet for
+// `segment`, or false when capture is off, the segment is font (0,1) where no
+// material exists, or a foreign tile bank is resident.
+static bool cbxMatSheets(tic_core* core, u8 segment, tic_tilesheet out[CBX_MAT_CHANNELS])
+{
+    if (!CbxMatPlane || segment < 2 || CbxTilesBank != 0) return false;
+    for (s32 c = 0; c < CBX_MAT_CHANNELS; c++)
+        out[c] = tic_tilesheet_get(segment, (u8*)&core->memory.cart.banks[CbxMatBank[c]].tiles);
+    return true;
+}
+
+// Encode 5 raw ramp levels (0..15) into the material planes at a screen pixel.
+// R = raw normal direction index (shader reads m.r*255 as the index); G/B/A and
+// the emissive plane = the 0..15 ramp scaled to a full 0..255 byte (15*17==255).
+static inline void cbxEncode(s32 pixel, u8 normal, u8 height, u8 specular, u8 roughness, u8 emissive)
+{
+    if (!CbxMatPlane || pixel < 0 || pixel >= TIC80_WIDTH * TIC80_HEIGHT) return;
+    u32 base = pixel * 4;
+    CbxMatPlane[base + 0] = cbxClampLevel(normal);
+    CbxMatPlane[base + 1] = (u8)(cbxClampLevel(height) * 17);
+    CbxMatPlane[base + 2] = (u8)(cbxClampLevel(specular) * 17);
+    CbxMatPlane[base + 3] = (u8)(cbxClampLevel(roughness) * 17);
+    if (CbxEmisPlane) CbxEmisPlane[pixel] = (u8)(cbxClampLevel(emissive) * 17);
+}
+
+// Emit material sampled from per-tile pointers (spr/map path). `pixel` is the
+// linear screen index; `sx,sy` the source texel within the tile (after the same
+// flip/rotate the colour used).
+static inline void cbxWriteMat(s32 pixel, const tic_tileptr* mt, s32 sx, s32 sy)
+{
+    cbxEncode(pixel,
+              tic_tilesheet_gettilepix(&mt[0], sx, sy), tic_tilesheet_gettilepix(&mt[1], sx, sy),
+              tic_tilesheet_gettilepix(&mt[2], sx, sy), tic_tilesheet_gettilepix(&mt[3], sx, sy),
+              tic_tilesheet_gettilepix(&mt[4], sx, sy));
+}
+
+// Emit material sampled at sheet-level coords (textured-triangle tile path,
+// which reads the colour with tic_tilesheet_getpix rather than a tile pointer).
+static inline void cbxWriteMatSheet(s32 pixel, const tic_tilesheet* sheets, s32 sx, s32 sy)
+{
+    cbxEncode(pixel,
+              tic_tilesheet_getpix(&sheets[0], sx, sy), tic_tilesheet_getpix(&sheets[1], sx, sy),
+              tic_tilesheet_getpix(&sheets[2], sx, sy), tic_tilesheet_getpix(&sheets[3], sx, sy),
+              tic_tilesheet_getpix(&sheets[4], sx, sy));
+}
+
+// Reset a screen region to the flat-matte default (normal 0 facing camera,
+// height/specular 0, roughness full, emissive 0). Called by tic_api_cls so
+// material tracks VRAM: whatever cls clears, this rematte-s.
+static void cbxMatteRegion(s32 l, s32 t, s32 r, s32 b)
+{
+    if (!CbxMatPlane) return;
+    if (l < 0) l = 0;
+    if (t < 0) t = 0;
+    if (r > TIC80_WIDTH) r = TIC80_WIDTH;
+    if (b > TIC80_HEIGHT) b = TIC80_HEIGHT;
+    for (s32 y = t; y < b; y++)
+        for (s32 x = l, p = y * TIC80_WIDTH + x; x < r; x++, p++)
+        {
+            CbxMatPlane[p * 4 + 0] = 0;
+            CbxMatPlane[p * 4 + 1] = 0;
+            CbxMatPlane[p * 4 + 2] = 0;
+            CbxMatPlane[p * 4 + 3] = 255;
+            if (CbxEmisPlane) CbxEmisPlane[p] = 0;
+        }
+}
